# ChiYan-Web · 全栈凭证总清单（VPS 自部署版）
# ─────────────────────────────────────────────────────────────────────────────
# 用法：
#   1. 复制为 .env.local（已在根 .gitignore，**永远不要 commit**）
#   2. 按下列分组依次填入；同一字段在多处出现时以本文件为单一来源
#   3. 把对应字段同步到 apps/api/.env / apps/h5/.env.local / apps/admin/.env.local
#      （这三处是各 app 的运行时配置，根目录的 .env.local 只作汇总参考）
#   4. prod 部署时通过 systemd EnvironmentFile=/etc/chiyan/secrets.env 注入 chiyan-api.service
#      （详见 docs/部署架构.md §3.1）；**不进 git**
#
# 凭证泄漏一律视作公开 —— 任何字段贴到聊天 / issue / PR 都必须立即在源平台 reset。
# ─────────────────────────────────────────────────────────────────────────────


# ┌─────────────────────────────────────────────────────────────────────────┐
# │ 1. Postgres × 3（dev 本机；staging / prod 各 VPS 本机 postgresql.service） │
# │    role: chiyan_owner（scram-sha-256，localhost-only）                  │
# └─────────────────────────────────────────────────────────────────────────┘
DATABASE_URL_DEV=postgresql://chiyan:<dev-password>@127.0.0.1:5432/chiyan_dev
DATABASE_URL_STAGING=postgresql://chiyan:<staging-password>@127.0.0.1:5432/chiyan_staging
DATABASE_URL_PROD=postgresql://chiyan:<prod-password>@127.0.0.1:5432/chiyan_prod


# ┌─────────────────────────────────────────────────────────────────────────┐
# │ 2. Redis（本机 redis-server，密码鉴权，bind 127.0.0.1）                │
# └─────────────────────────────────────────────────────────────────────────┘
REDIS_URL=redis://:<redis-password>@127.0.0.1:6379/0


# ┌─────────────────────────────────────────────────────────────────────────┐
# │ 3. 媒体存储（本地磁盘）                                                 │
# │    MEDIA_ROOT：systemd chiyan-api.service ReadWritePaths 唯一写入路径   │
# │    API_PUBLIC_URL：sign endpoint 拼绝对 upload_url 用                   │
# └─────────────────────────────────────────────────────────────────────────┘
MEDIA_ROOT=/var/chiyan/media
API_PUBLIC_URL=https://api.chiyan.com


# ┌─────────────────────────────────────────────────────────────────────────┐
# │ 4. Cloudflare（DNS proxied + Cache-Tag purge）                          │
# │    DNS / 边缘缓存仍在；Workers / R2 / Pages **不用**                   │
# │    Permissions: Zone → Cache Purge → Purge                              │
# └─────────────────────────────────────────────────────────────────────────┘
CF_API_TOKEN=<token>
CF_ZONE_ID=<域名 overview 右下角 Zone ID>


# ┌─────────────────────────────────────────────────────────────────────────┐
# │ 5. （不接入 Sentry —— 监控只用本机 journalctl，无外部上报）              │
# └─────────────────────────────────────────────────────────────────────────┘


# ┌─────────────────────────────────────────────────────────────────────────┐
# │ 6. API 自有 secrets（与外部平台无关，本地生成）                         │
# │    JWT_SECRET   : openssl rand -base64 48                               │
# │    ENC_KEY_V1   : openssl rand -base64 32（real_name / totp_secret 加密）│
# │    ENC_KEY_V2   : 轮换准备位，初始为空                                  │
# └─────────────────────────────────────────────────────────────────────────┘
JWT_SECRET=<≥32 字节随机字符串>
ENC_KEY_V1=<base64 编码的 32 字节>
ENC_KEY_V2=


# ┌─────────────────────────────────────────────────────────────────────────┐
# │ 7. 业务硬编码项                                                          │
# └─────────────────────────────────────────────────────────────────────────┘
STUDIO_QQ=<工作室对外 QQ 号>


# ─────────────────────────────────────────────────────────────────────────────
# 同步指引（哪个字段放到哪里）
# ─────────────────────────────────────────────────────────────────────────────
#
# apps/api/.env  ← ENV / PORT / ALLOWED_ORIGINS / DATABASE_URL (= DATABASE_URL_DEV)
#                  REDIS_URL / MEDIA_ROOT / API_PUBLIC_URL /
#                  JWT_SECRET / ENC_KEY_V1 / ENC_KEY_V2 /
#                  CF_API_TOKEN / CF_ZONE_ID
#
# apps/h5/.env.local  ← 仅 VITE_ 前缀字段（见 apps/h5/.env.example）
#
# apps/admin/.env.local ← 同 h5
#
# /etc/chiyan/secrets.env （VPS）← 6.1-6.3 + 1-3 prod 值，systemd 注入 chiyan-api.service
