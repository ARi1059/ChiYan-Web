# ChiYan-Web · 全栈凭证总清单
# ─────────────────────────────────────────────────────────────────────────────
# 用法：
#   1. 复制为 .env.local（已在根 .gitignore，**永远不要 commit**）
#   2. 按下列分组依次填入；同一字段在多处出现时（如 DATABASE_URL）以本文件为单一来源
#   3. 把对应字段同步到 apps/api/.dev.vars / apps/h5/.env.local / apps/admin/.env.local
#      （这三处是各 app 的运行时配置，根目录的 .env.local 只作汇总参考）
#   4. prod 部署时通过 `wrangler secret put <NAME>` 注入 Workers，**不进 git**
#
# 凭证泄漏一律视作公开 —— 任何字段贴到聊天 / issue / PR 都必须立即在源平台 reset。
# ─────────────────────────────────────────────────────────────────────────────


# ┌─────────────────────────────────────────────────────────────────────────┐
# │ 1. Neon Postgres × 3（dev / staging / prod 三个 branch，同一 project）  │
# │    role: neondb_owner（pooled connection，HTTP 驱动用）                 │
# └─────────────────────────────────────────────────────────────────────────┘
NEON_DEV_URL=postgresql://neondb_owner:<password>@ep-xxx-pooler.<region>.aws.neon.tech/neondb?sslmode=require&channel_binding=require
NEON_STAGING_URL=postgresql://neondb_owner:<password>@ep-xxx-pooler.<region>.aws.neon.tech/neondb?sslmode=require&channel_binding=require
NEON_PROD_URL=postgresql://neondb_owner:<password>@ep-xxx-pooler.<region>.aws.neon.tech/neondb?sslmode=require&channel_binding=require


# ┌─────────────────────────────────────────────────────────────────────────┐
# │ 2. Upstash Redis × 2（HTTPS REST API，不要用 redis:// TCP 端点）        │
# │    chiyan-ratelimit: 限流滑动窗口                                       │
# │    chiyan-session  : jti 黑名单 + 一次性 challenge token                │
# └─────────────────────────────────────────────────────────────────────────┘
UPSTASH_RATELIMIT_REST_URL=https://<id>.upstash.io
UPSTASH_RATELIMIT_REST_TOKEN=<token>
UPSTASH_SESSION_REST_URL=https://<id>.upstash.io
UPSTASH_SESSION_REST_TOKEN=<token>


# ┌─────────────────────────────────────────────────────────────────────────┐
# │ 3. Cloudflare R2（S3 兼容 API + bucket binding）                        │
# │    chiyan-public  : 公开图片 / 缩略图 / 水印副本（CDN 直挂）            │
# │    chiyan-private : 原图 / 模卡高清（仅 Workers 鉴权访问）              │
# └─────────────────────────────────────────────────────────────────────────┘
CF_ACCOUNT_ID=<32 字符 hex>
R2_ACCESS_KEY_ID=<key id>
R2_SECRET_ACCESS_KEY=<secret>
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_PUBLIC_BUCKET=chiyan-public
R2_PRIVATE_BUCKET=chiyan-private
R2_PUBLIC_CDN_HOST=cdn.example.com   # 自定义子域；未绑则用 pub-xxx.r2.dev


# ┌─────────────────────────────────────────────────────────────────────────┐
# │ 4. Cloudflare API Token（cache purge 用，最小权限）                     │
# │    创建路径: My Profile → API Tokens → Custom token                     │
# │    Permissions: Zone → Cache Purge → Purge                              │
# │    Zone Resources: Include → Specific zone → <你的域名>                 │
# └─────────────────────────────────────────────────────────────────────────┘
CF_API_TOKEN=<token>
CF_ZONE_ID=<域名 overview 右下角 Zone ID>


# ┌─────────────────────────────────────────────────────────────────────────┐
# │ 5. Sentry DSN × 3（H5 / Admin 浏览器 SDK + Workers SDK 各一）           │
# └─────────────────────────────────────────────────────────────────────────┘
SENTRY_DSN_H5=https://<key>@o<org>.ingest.sentry.io/<project>
SENTRY_DSN_ADMIN=https://<key>@o<org>.ingest.sentry.io/<project>
SENTRY_DSN_API=https://<key>@o<org>.ingest.sentry.io/<project>


# ┌─────────────────────────────────────────────────────────────────────────┐
# │ 6. API 自有 secrets（与外部平台无关，本地生成）                         │
# │    JWT_SECRET   : openssl rand -base64 48                               │
# │    ENC_KEY_V1   : openssl rand -base64 32（real_name / totp_secret 加密）│
# │    ENC_KEY_V2   : 轮换准备位，初始为空                                  │
# └─────────────────────────────────────────────────────────────────────────┘
JWT_SECRET=<≥32 字节随机字符串>
ENC_KEY_V1=<base64 编码的 32 字节>
ENC_KEY_V2=


# ┌─────────────────────────────────────────────────────────────────────────┐
# │ 7. 业务硬编码项                                                          │
# └─────────────────────────────────────────────────────────────────────────┘
STUDIO_QQ=<工作室对外 QQ 号>


# ─────────────────────────────────────────────────────────────────────────────
# 同步指引（哪个字段放到哪里）
# ─────────────────────────────────────────────────────────────────────────────
#
# apps/api/.dev.vars  ← 全部 1-7 项（除 SENTRY_DSN_H5 / SENTRY_DSN_ADMIN 之外）
#                       DATABASE_URL 取 NEON_DEV_URL（dev 默认）
#
# apps/h5/.env.local  ← 仅 VITE_ 前缀字段（见 apps/h5/.env.example）
#                       Vite 只暴露 VITE_* 给浏览器；其他变量不可用
#
# apps/admin/.env.local ← 同 h5
#
# wrangler secret put  ← prod 部署时，1-6 全部通过命令注入，**不能写进 wrangler.toml**
#                        参考: pnpm -F @chiyan/api exec wrangler secret put DATABASE_URL --env production
