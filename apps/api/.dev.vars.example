# apps/api/.dev.vars · Workers 本地开发凭证
# ─────────────────────────────────────────────────────────────────────────────
# 用法：
#   1. 复制为 apps/api/.dev.vars（已在 .gitignore）
#   2. 字段值从根目录 .env.local 同步（根目录是单一来源，参见 .env.example）
#   3. `wrangler dev` 启动时自动读取；与 wrangler.toml 的 [vars] 块合并（这里优先级更高）
#   4. prod 部署用 `wrangler secret put <NAME> --env production`，绝不写进 wrangler.toml
# ─────────────────────────────────────────────────────────────────────────────


# ─── ENV-aware（wrangler.toml [vars] 已给 dev 默认值，下面是覆盖通道） ───
# ENV=dev
# ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:5174","http://localhost:8787"]


# ─── 1. Neon Postgres（dev 用 NEON_DEV_URL） ───
DATABASE_URL=postgresql://neondb_owner:<password>@ep-xxx-pooler.<region>.aws.neon.tech/neondb?sslmode=require&channel_binding=require


# ─── 2. Upstash Redis × 2 ───
UPSTASH_RATELIMIT_REST_URL=https://<id>.upstash.io
UPSTASH_RATELIMIT_REST_TOKEN=<token>
UPSTASH_SESSION_REST_URL=https://<id>.upstash.io
UPSTASH_SESSION_REST_TOKEN=<token>


# ─── 3. Cloudflare R2（S3 兼容 API） ───
CF_ACCOUNT_ID=<32 字符 hex>
R2_ACCESS_KEY_ID=<key id>
R2_SECRET_ACCESS_KEY=<secret>
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_PUBLIC_BUCKET=chiyan-public
R2_PRIVATE_BUCKET=chiyan-private
R2_PUBLIC_CDN_HOST=cdn.example.com


# ─── 4. Cloudflare cache purge（Phase 3 admin 写路径触发；空则 cf-cache 自动 no-op） ───
CF_API_TOKEN=<token>
CF_ZONE_ID=<zone id>


# ─── 5. Sentry（Workers SDK 用） ───
SENTRY_DSN_API=https://<key>@o<org>.ingest.sentry.io/<project>


# ─── 6. API 自有 secrets（本地生成，每个环境独立） ───
# JWT_SECRET:   openssl rand -base64 48
# ENC_KEY_V1:   openssl rand -base64 32
# ENC_KEY_V2:   轮换准备位，初始留空
JWT_SECRET=<≥32 字节随机字符串>
ENC_KEY_V1=<base64 编码的 32 字节>
ENC_KEY_V2=


# ─── 7. 业务硬编码项 ───
STUDIO_QQ=<工作室对外 QQ 号>
