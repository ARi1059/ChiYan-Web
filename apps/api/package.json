{
  "name": "@chiyan/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:prod": "wrangler deploy --env production",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist .wrangler"
  },
  "dependencies": {
    "@chiyan/db": "workspace:*",
    "@chiyan/types": "workspace:*",
    "hono": "^4.6.14",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@chiyan/config": "workspace:*",
    "@cloudflare/workers-types": "^4.20241224.0",
    "eslint": "^9.17.0",
    "typescript": "~5.7.2",
    "wrangler": "^3.99.0"
  }
}
