{
  "name": "@chiyan/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:prod": "wrangler deploy --env production",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .wrangler"
  },
  "dependencies": {
    "@chiyan/db": "workspace:*",
    "@chiyan/types": "workspace:*",
    "bcryptjs": "^3.0.3",
    "hono": "^4.6.14",
    "otpauth": "^9.5.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@chiyan/config": "workspace:*",
    "@cloudflare/vitest-pool-workers": "^0.16",
    "@cloudflare/workers-types": "^4.20241224.0",
    "@types/bcryptjs": "^3.0.0",
    "eslint": "^9.17.0",
    "typescript": "~5.7.2",
    "vitest": "^4",
    "wrangler": "^3.99.0"
  }
}
