# apps/api/.env.example · API 进程的环境变量模板
# ─────────────────────────────────────────────────────────────────────────────
# 用法：
#   1. 复制为 apps/api/.env（已在 .gitignore）
#   2. 字段值从根目录 .env.local 同步（根目录是单一来源）
#   3. dev 启动时 dotenv 自动读取；prod 由 systemd EnvironmentFile=/etc/chiyan/secrets.env 注入
# ─────────────────────────────────────────────────────────────────────────────


# ─── 0. 运行时 ───
ENV=dev
PORT=3000
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:5174","http://localhost:3000"]


# ─── 1. Postgres（本机 127.0.0.1，systemd 启的 postgresql.service） ───
DATABASE_URL=postgresql://chiyan:<password>@127.0.0.1:5432/chiyan_dev


# ─── 2. Redis（本机 127.0.0.1，systemd 启的 redis-server，密码鉴权） ───
REDIS_URL=redis://:<redis-password>@127.0.0.1:6379/0


# ─── 3. 媒体存储 ───
MEDIA_ROOT=/var/chiyan/media
API_PUBLIC_URL=https://api.chiyan.com


# ─── 4. Cloudflare cache purge（DNS 走 proxied，写路径触发 purge_cache by Cache-Tag） ───
# 留空 → cf-cache 自动 no-op，开发期常态
CF_API_TOKEN=
CF_ZONE_ID=


# ─── 5. API 自有 secrets（本地生成） ───
# JWT_SECRET:   openssl rand -base64 48
# ENC_KEY_V1:   openssl rand -base64 32（real_name / totp_secret 加密）
# ENC_KEY_V2:   轮换准备位，初始留空
JWT_SECRET=<≥32 字节随机字符串>
ENC_KEY_V1=<base64 编码的 32 字节>
ENC_KEY_V2=
