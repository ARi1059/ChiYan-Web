# apps/h5/.env.local · H5 客户端浏览器端配置
# ─────────────────────────────────────────────────────────────────────────────
# 复制为 apps/h5/.env.local（已在 .gitignore）
# Vite 规则：只有 VITE_ 前缀的变量才会暴露给浏览器；其他变量不可用
# 浏览器端可见 = 公开 —— 任何敏感 token 都不能放这里
# ─────────────────────────────────────────────────────────────────────────────

# API 基地址（dev 同源走 vite proxy 即可留空；prod 写主域 api 子路径）
VITE_API_BASE=/api/v1

# 工作室对外 QQ（接单链路硬编码项）
VITE_STUDIO_QQ=<工作室对外 QQ 号>
