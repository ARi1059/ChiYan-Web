# apps/admin/.env.local · Admin Console 浏览器端配置
# ─────────────────────────────────────────────────────────────────────────────
# 复制为 apps/admin/.env.local（已在 .gitignore）
# Vite 规则：只有 VITE_ 前缀的变量才会暴露给浏览器
# Admin 自身也是浏览器应用，敏感 token 同样不能放这里 —— 鉴权全走 cookie + JWT
# ─────────────────────────────────────────────────────────────────────────────

# API 基地址（dev 同源走 vite proxy；prod 走 admin 子域调 api 子域，需配 CORS）
VITE_API_BASE=/api/v1
