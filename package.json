{
  "name": "chiyan-web",
  "version": "0.0.0",
  "private": true,
  "description": "ChiYan H5 + Admin Console + API — VPS self-hosted (Node + Postgres + Redis + Caddy)",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm -r --parallel --filter \"./apps/*\" run dev",
    "dev:h5": "pnpm --filter @chiyan/h5 run dev",
    "dev:admin": "pnpm --filter @chiyan/admin run dev",
    "dev:api": "pnpm --filter @chiyan/api run dev",
    "build": "pnpm -r --filter \"./apps/*\" run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml,css}\" --ignore-path .gitignore --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml,css}\" --ignore-path .gitignore --ignore-path .prettierignore",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:migrate": "pnpm --filter @chiyan/db migrate",
    "db:generate": "pnpm --filter @chiyan/db generate",
    "clean": "pnpm -r run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.10.0",
    "otpauth": "^9.5.1",
    "prettier": "^3.4.0",
    "typescript": "~5.7.2"
  }
}
